{
  "info": {
    "name": "vLLM Semantic Router",
    "description": "API tests for vLLM Semantic Router (vSR).\n\nSet the environment variables:\n- `api_base_url`: Classification API route\n- `envoy_base_url`: Envoy proxy route (chat completions)\n- `metrics_base_url`: Prometheus metrics route\n- `routing_api_base_url`: (DEPRECATED - routing API is now served on api_base_url)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [],
  "item": [
    {
      "name": "Health & Readiness",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_base_url}}/health",
              "host": ["{{api_base_url}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Readiness Check",
