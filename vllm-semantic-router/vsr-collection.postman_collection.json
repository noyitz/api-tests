    {
      "name": "Envoy Routing (ExtProc)",
      "description": "Requests go through Envoy, which calls vSR via gRPC ExtProc for routing decisions. Check response HEADERS for x-vsr-* fields.",
      "item": [
        {
          "name": "Auto Route - Math Question",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"auto\",\n  \"messages\": [\n    {\"role\": \"user\", \"content\": \"What is 2+2?\"}\n  ]\n}"
            },
            "url": {
              "raw": "{{envoy_base_url}}/v1/chat/completions",
              "host": ["{{envoy_base_url}}"],
